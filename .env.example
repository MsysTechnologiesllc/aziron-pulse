# Environment variables for Aziron Pulse

# Server configuration
PULSE_PORT=8081

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=aziron
DB_SSLMODE=disable

# JWT Authentication (must match aziron-server)
JWT_SECRET=your-secret-key-here

# Kubernetes Configuration
KUBECONFIG=~/.kube/config
BASE_IMAGE=codercom/code-server:latest

# Workspace Configuration
AZIRON_WORKSPACE=/var/aziron/workspace

# Pod Resource Defaults
DEFAULT_CPU_LIMIT=2.0
DEFAULT_MEMORY_MB=4096
DEFAULT_STORAGE_GB=10

# TTL Configuration
TTL_CHECK_INTERVAL=5  # minutes
DEFAULT_TTL_MINUTES=120  # 2 hours

# OpenTelemetry configuration
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4318
OTEL_SERVICE_NAME=aziron-pulse

# Tracing Sampling Rates
TRACE_SAMPLE_ERROR_RATE=1.0        # 100% of errors
TRACE_SAMPLE_SUCCESS_RATE=0.1      # 10% of successful operations
TRACE_SAMPLE_HIGH_VOLUME_RATE=0.01 # 1% of high-volume operations (watch, metrics)

# Pyroscope Profiling
PYROSCOPE_SERVER_URL=http://localhost:4040
PYROSCOPE_AUTH_TOKEN=                    # Optional
ENVIRONMENT=development                   # production, staging, development

# Kubernetes Cluster Configuration (for network filtering)
CLUSTER_POD_CIDR=10.244.0.0/16           # Default for flannel/kind
CLUSTER_SERVICE_CIDR=10.96.0.0/12        # Default service CIDR

# Cost Calculation - Resource Level
COST_CPU_PER_HOUR=0.04                   # USD per CPU core per hour
COST_MEMORY_PER_GB_HOUR=0.005            # USD per GB memory per hour
COST_STORAGE_PER_GB_HOUR=0.0001          # USD per GB storage per hour
COST_NETWORK_PER_GB=0.09                 # USD per GB network egress

# Cost Calculation - Instance Tier Mapping (JSON format)
# Format: [{"name":"tier_name","cpu":2.0,"memory_gb":4.0,"cost_per_hour":0.04,"type":"balanced"}]
INSTANCE_TIER_MAPPING='[{"name":"burstable_small","cpu":0.5,"memory_gb":1,"cost_per_hour":0.01,"type":"burstable"},{"name":"burstable_medium","cpu":1.0,"memory_gb":2,"cost_per_hour":0.02,"type":"burstable"},{"name":"burstable_large","cpu":2.0,"memory_gb":4,"cost_per_hour":0.04,"type":"burstable"},{"name":"compute_optimized_small","cpu":2.0,"memory_gb":2,"cost_per_hour":0.05,"type":"compute_optimized"},{"name":"compute_optimized_medium","cpu":4.0,"memory_gb":4,"cost_per_hour":0.10,"type":"compute_optimized"},{"name":"balanced_small","cpu":1.0,"memory_gb":4,"cost_per_hour":0.035,"type":"balanced"},{"name":"balanced_medium","cpu":2.0,"memory_gb":8,"cost_per_hour":0.07,"type":"balanced"},{"name":"memory_optimized_small","cpu":1.0,"memory_gb":8,"cost_per_hour":0.06,"type":"memory_optimized"},{"name":"memory_optimized_medium","cpu":2.0,"memory_gb":16,"cost_per_hour":0.12,"type":"memory_optimized"}]'

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILTER_MODE=strict  # strict, relaxed, off
